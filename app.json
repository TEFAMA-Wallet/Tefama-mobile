{
  "expo": {
    "name": "Tefama",
    "slug": "tefama-mobile",
    "scheme": "tefama",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/branding/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "icon": "./assets/branding/app-icon.png",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/branding/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "package": "com.tefama.mobile"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tefama.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "3ac3c39b-a622-45fc-964c-daed9ed4019d"
      }
    },
    "owner": "tevinprime66"
  }
}
