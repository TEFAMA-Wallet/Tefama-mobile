{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "android": {
        "resourceClass": "default",
        "buildType": "apk"
      },
      "ios": {
        "resourceClass": "m-medium",
        "simulator": false
      }
    },
    "simulator": {
      "ios": {
        "resourceClass": "m-medium",
        "simulator": true
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "resourceClass": "default",
        "buildType": "app-bundle"
      },
      "ios": {
        "resourceClass": "m-medium"
      }
    }
  }
}
